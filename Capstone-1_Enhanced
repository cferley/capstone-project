    "    print(f\"✓ Filters applied: {len(filtered_df):,} records match criteria\")\n",
    "\n",
    "# Connect the update function to the button click event\n",
    "update_button.on_click(update_df)\n",
    "\n",
    "print(\"✓ Data filtering logic configured\")"
