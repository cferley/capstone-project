    "    if geo_desc_choice.value:\n",
    "        filtered_df = filtered_df[\n",
    "            filtered_df['Rndrng_Prvdr_Geo_Desc'].astype(str).isin(geo_desc_choice.value)\n",
    "        ]\n",
    "\n",
    "    # FILTER 5: DRG Description\n",
    "    # Only apply if user selected specific procedures\n",
    "    if drg_desc_choice.value:\n",
    "        filtered_df = filtered_df[\n",
    "            filtered_df['DRG_Desc'].astype(str).isin(drg_desc_choice.value)\n",
    "        ]\n",
    "\n",
    "    # FILTER 6: Total Discharges Range\n",
    "    # Apply discharge volume filter\n",
    "    disch_min, disch_max = tot_discharges_slider.value\n",
    "    filtered_df = filtered_df[\n",
    "        filtered_df['Tot_Dschrgs'].between(disch_min, disch_max)\n",
    "    ]\n",
    "\n",
    "    # FILTER 7: Covered Charges Range\n",
    "    # Apply submitted charge filter\n",
    "    cov_min, cov_max = covered_charge_slider.value\n",
    "    filtered_df = filtered_df[\n",
    "        filtered_df['Avg_Submtd_Cvrd_Chrg'].between(cov_min, cov_max)\n",
    "    ]\n",
    "\n",
    "    # FILTER 8: Total Payments Range\n",
    "    # Apply total payment filter\n",
    "    tot_min, tot_max = total_payment_slider.value\n",
    "    filtered_df = filtered_df[\n",
    "        filtered_df['Avg_Tot_Pymt_Amt'].between(tot_min, tot_max)\n",
    "    ]\n",
    "\n",
    "    # FILTER 9: Medicare Payments Range\n",
    "    # Apply Medicare payment filter\n",
    "    med_min, med_max = medicare_payment_slider.value\n",
    "    filtered_df = filtered_df[\n",
    "        filtered_df['Avg_Mdcr_Pymt_Amt'].between(med_min, med_max)\n",
    "    ]\n",
    "\n",
    "    # Update the reactive DataFrame\n",
    "    # This triggers all @pn.depends(target_df.param.data) functions\n",
    "    target_df.data = filtered_df\n",
    "\n",
    "    # Reset button to default state\n",
