    "# VISUALIZATION FUNCTION 1: Top DRGs by Discharge Volume\n",
    "# Type: Aggregation/Comparison (Bar Chart)\n",
    "# Purpose: Identify most common procedures\n",
    "\n",
    "def bar_top_drg_discharge(data, figsize=(7, 4)):\n",
    "    \"\"\"\n",
    "    Creates horizontal bar chart of top 10 DRGs by total discharges.\n",
    "    \n",
    "    Parameters:\n",
    "    - data: Filtered DataFrame\n",
    "    - figsize: Tuple of (width, height) in inches\n",
    "    \n",
    "    Returns:\n",
    "    - matplotlib Figure object\n",
    "    \"\"\"\n",
    "    # Aggregate total discharges by DRG description\n",
    "    # Using .astype(str) to handle category dtype\n",
    "    top_drgs = (\n",
    "        data.groupby(data[\"DRG_Desc\"].astype(str))[\"Tot_Dschrgs\"]\n",
    "        .sum()\n",
    "        .sort_values(ascending=False)\n",
    "        .head(10)  # Get top 10 only\n",
    "    )\n",
    "    \n",
    "    # Create figure and axis\n",
    "    fig, ax = plt.subplots(figsize=figsize)\n",
    "    \n",
    "    # Create horizontal bar chart (easier to read long DRG names)\n",
    "    top_drgs.plot(kind=\"barh\", ax=ax, color=\"steelblue\")\n",
    "    \n",
    "    # Add labels and title\n",
    "    ax.set_xlabel(\"Total Discharges\", fontsize=11)\n",
    "    ax.set_ylabel(\"DRG Description\", fontsize=11)\n",
    "    ax.set_title(\"Top 10 DRGs by Discharge Volume\", fontsize=13, fontweight=\"bold\")\n",
    "    \n",
    "    # Format x-axis to show numbers with commas\n",
    "    ax.xaxis.set_major_formatter(plt.FuncFormatter(lambda x, p: f'{int(x):,}'))\n",
    "    \n",
    "    # Improve layout\n",
    "    plt.tight_layout()\n",
    "    \n",
    "    return fig"
