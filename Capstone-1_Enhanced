    "# =============================================================================\n",
    "# DASHBOARD ASSEMBLY WITH COLLAPSIBLE SIDEBAR\n",
    "# =============================================================================\n",
    "\n",
    "# Create hamburger toggle button for sidebar\n",
    "# Allows users to hide sidebar to see more of the visualizations\n",
    "hamburger = pn.widgets.Toggle(\n",
    "    name=\"☰\",  # Hamburger menu icon\n",
    "    button_type=\"default\",\n",
    "    width=50,\n",
    "    value=True  # Sidebar visible by default\n",
    ")\n",
    "\n",
    "# Combine all components into final dashboard layout\n",
    "dashboard = pn.Row(\n",
    "    pn.Column(hamburger, sidebar),  # Left side: toggle + sidebar\n",
    "    main_content  # Right side: visualizations\n",
    ")\n",
    "\n",
    "# Function to toggle sidebar visibility\n",
    "@pn.depends(hamburger.param.value, watch=True)\n",
    "def toggle_sidebar(show):\n",
    "    \"\"\"\n",
    "    Show/hide sidebar based on toggle button state.\n",
    "    Also changes button icon (☰ when hidden, ✖ when visible).\n",
    "    \"\"\"\n",
    "    sidebar.visible = show\n",
    "    hamburger.name = \"✖\" if show else \"☰\"\n",
    "\n",
    "# Initialize sidebar visibility\n",
    "toggle_sidebar(hamburger.value)\n",
    "\n",
    "# Make dashboard servable (required for Panel apps)\n",
    "dashboard.servable()\n",
    "\n",
    "print(\"✓ Dashboard fully assembled and ready!\")\n",
    "print(\"\\n\" + \"=\"*70)\n",
    "print(\"DASHBOARD READY - Display it below:\")\n",
