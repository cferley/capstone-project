    "# VISUALIZATION FUNCTION 4: Total Discharges Over Time\n",
    "# Type: Trend Analysis (Line Plot)\n",
    "# Purpose: Track Medicare utilization year-over-year\n",
    "\n",
    "def line_total_discharges_over_time(data, figsize=(7, 4)):\n",
    "    \"\"\"\n",
    "    Creates line plot showing total discharges by year.\n",
    "    \n",
    "    Analytical insight: Look for:\n",
    "    - Overall trend (increasing/decreasing utilization)\n",
    "    - Sudden changes (e.g., COVID-19 impact in 2020)\n",
    "    - Seasonal patterns (if monthly data were available)\n",
    "    \"\"\"\n",
    "    # Aggregate total discharges by year\n",
    "    yearly_totals = (\n",
    "        data.groupby(data[\"Year\"].astype(int))[\"Tot_Dschrgs\"]\n",
